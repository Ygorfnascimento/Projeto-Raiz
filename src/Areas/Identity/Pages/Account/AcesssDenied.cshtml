@page
@model Microsoft.AspNetCore.Identity.UI.V5.Pages.Account.Internal.AccessDeniedModel
@{
    ViewData["Title"] = "Acesso negado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="text-danger" style="font-size: 4rem;"><i class="bi bi-shield-lock"></i></h1>
            <h2 class="text-danger">@ViewData["Title"]</h2>
            <hr />
            
            <div class="alert alert-light border-warning shadow-sm">
                <h4 class="alert-heading text-warning">Atenção, Operador!</h4>
                <p class="mb-0">
                    Sua conta possui o perfil de <strong>OPERADOR</strong>. 
                    Você não tem permissão para acessar este recurso ou realizar esta operação.
                </p>
                <p class="mt-2 text-muted small">
                    Caso acredite que isso seja um erro, entre em contato com o administrador do sistema.
                </p>
            </div>

            <div class="mt-4">
                <a href="/" class="btn btn-primary px-4">Voltar para o Início</a>
                <button onclick="history.back()" class="btn btn-outline-secondary px-4">Voltar à página anterior</button>
            </div>
        </div>
    </div>
</div>