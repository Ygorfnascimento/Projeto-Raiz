@using Raiz.Models;
@model ProdutoCadastroViewModel;

<h1 class="mt-4">Editar Produto</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item">Cadastro</li>
    <li class="breadcrumb-item"><a asp-action="Index">Produtos</a></li>
    <li class="breadcrumb-item active">Edição</li>
</ol>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-exclamation-circle me-1"></i> @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4 shadow-sm border-left-warning">
    <div class="card-header py-3 bg-white">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-edit me-1"></i> Alterar Informações do Produto
        </h6>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProdutoId" />

            <div class="row g-3">
                <div class="col-md-4 mb-3">
                    <label asp-for="CodigoBarras" class="form-label small font-weight-bold">Código de Barras</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fas fa-barcode"></i></span>
                        <input asp-for="CodigoBarras" class="form-control" />
                    </div>
                    <span asp-validation-for="CodigoBarras" class="text-danger small"></span>
                </div>

                <div class="col-md-8 mb-3">
                    <label asp-for="Nome" class="form-label small font-weight-bold">Nome do Produto</label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="Descricao" class="form-label small font-weight-bold">Descrição Detalhada</label>
                    <textarea asp-for="Descricao" class="form-control" rows="2">@Model.Descricao</textarea>
                    <span asp-validation-for="Descricao" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6 mb-3">
                    <label asp-for="Preco" class="form-label small font-weight-bold">Preço de Venda</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light">R$</span>
                        <input asp-for="Preco" type="number" step="0.01" min="0" class="form-control" />
                    </div>
                    <span asp-validation-for="Preco" class="text-danger small"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="CategoriaId" class="form-label small font-weight-bold">Categoria</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fas fa-tags"></i></span>
                        <select asp-for="CategoriaId" asp-items="Model.Categorias" class="form-select">
                            <option value="">Selecione uma categoria...</option>
                        </select>
                    </div>
                    <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                </div>
            </div>

            <div class="mt-4 border-top pt-3 d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-secondary me-2 shadow-sm">
                    <i class="fas fa-arrow-left me-1"></i> Voltar
                </a>
                <button type="submit" class="btn btn-primary shadow-sm">
                    <i class="fas fa-save me-1"></i> Salvar Alterações
                </button>
            </div>
        </form>
    </div>
</div>

<div class="alert alert-info border-0 shadow-sm small">
    <i class="fas fa-lightbulb me-1"></i>
    <strong>Dica:</strong> Alterar o nome ou preço aqui não afeta as movimentações já finalizadas no histórico, apenas os novos registros.
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}