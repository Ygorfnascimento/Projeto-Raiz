@using Raiz.ViewModels
@model ProdutoPesquisaViewModel

<h1 class="mt-4">Produtos</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
    <li class="breadcrumb-item active">Produtos</li>
</ol>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i> @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Mensagem"] != null) 
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["Mensagem"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4 shadow-sm border-left-primary">
    <div class="card-header py-3 bg-white">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-filter me-1"></i> Filtro de Pesquisa
        </h6>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label asp-for="CodigoBarras" class="form-label small font-weight-bold">Código de Barras</label>
                    <input asp-for="CodigoBarras" class="form-control" placeholder="789..." />
                </div>
                <div class="col-md-5">
                    <label asp-for="Nome" class="form-label small font-weight-bold">Nome do Produto</label>
                    <input asp-for="Nome" class="form-control" placeholder="Digite parte do nome..." />
                </div>
                <div class="col-md-4 d-flex justify-content-end pb-1">
                    <button type="submit" class="btn btn-primary me-2 shadow-sm">
                        <i class="fas fa-search me-1"></i> Pesquisar
                    </button>
                    <a asp-action="Index" class="btn btn-secondary me-2 shadow-sm">Limpar</a>
                    
                    @if (User.IsInRole("Gerente"))
                    {
                        <a asp-action="Create" class="btn btn-success shadow-sm">
                            <i class="fas fa-plus me-1"></i> Novo Produto
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-header py-3 bg-light">
        <h6 class="m-0 font-weight-bold text-secondary text-uppercase small">
            <i class="fas fa-box me-1"></i> Itens Cadastrados
        </h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4" style="width: 15%">Cód. Barras</th>
                        <th style="width: 35%">Nome do Produto</th>
                        <th style="width: 15%">Categoria</th>
                        <th style="width: 15%">Preço Unit.</th>
                        <th class="text-center pe-4" style="width: 20%">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Resultados != null && Model.Resultados.Any())
                    {
                        foreach (var produto in Model.Resultados)
                        {
                            <tr>
                                <td class="ps-4 font-monospace small">@produto.CodigoBarras</td>
                                <td>
                                    <div class="font-weight-bold text-dark">@produto.Nome</div>
                                    <div class="small text-muted">ID: #@produto.ProdutoId</div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">
                                        <i class="fas fa-tag me-1 text-secondary"></i> @produto.CategoriaNome
                                    </span>
                                </td>
                                <td class="font-weight-bold text-primary">@produto.Preco.ToString("C")</td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-1">
                                        @if (User.IsInRole("Gerente"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@produto.ProdutoId" 
                                               class="btn btn-warning btn-sm text-white shadow-sm" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>

                                            <a asp-action="Delete" asp-route-id="@produto.ProdutoId" 
                                               class="btn btn-outline-danger btn-sm border-0" title="Remover">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic">Somente leitura</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="fas fa-box-open fa-3x mb-3 d-block text-muted opacity-25"></i>
                                <span class="text-muted">Nenhum produto encontrado na base de dados.</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>