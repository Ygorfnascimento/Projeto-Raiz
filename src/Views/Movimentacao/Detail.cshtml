@using Raiz.ViewModels;
@using Raiz.Enums;

@model MovimentacaoCadastroViewModel

<h1 class="mt-4">Detalhe de Movimentação</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a asp-controller="Movimentacao" asp-action="Index">Movimentação</a></li>
    <li class="breadcrumb-item active">Detalhe</li>
</ol>

@if (!string.IsNullOrEmpty(ViewBag.Mensagem))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-1"></i> @ViewBag.Mensagem
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4 shadow-sm border-left-info">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-info-circle me-1"></i> Dados da Movimentação
        </h6>
    </div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-1">
                <label class="form-label small font-weight-bold">Id</label>
                <input value="@Model.MovimentacaoId" class="form-control bg-light border-0" readonly />
            </div>

            <div class="col-md-2">
                <label class="form-label small font-weight-bold">Documento</label>
                <input value="@Model.Documento" class="form-control bg-light border-0 font-weight-bold" readonly />
            </div>

            <div class="col-md-2">
                <label class="form-label small font-weight-bold">Data</label>
                <input value="@Model.DataMovimentacao.ToShortDateString()" class="form-control bg-light border-0" readonly />
            </div>

            <div class="col-md-2">
                <label class="form-label small font-weight-bold">Tipo</label>
                @{
                    var badgeTipo = Model.TipoId == 1 ? "bg-primary" : "bg-info text-dark";
                }
                <div class="form-control bg-light border-0">
                    <span class="badge @badgeTipo">@((TipoMovimentacao)Model.TipoId)</span>
                </div>
            </div>

            <div class="col-md-2">
                <label class="form-label small font-weight-bold">Status</label>
                <div class="form-control bg-light border-0">
                    @if (Model.StatusId == 2)
                    {
                        <span class="badge bg-success">Finalizado</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Em Aberto</span>
                    }
                </div>
            </div>

            <div class="col-md-3 d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-secondary shadow-sm">
                    <i class="fas fa-arrow-left me-1"></i> Voltar para Lista
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-header py-3 bg-light">
        <h6 class="m-0 font-weight-bold text-secondary">
            <i class="fas fa-boxes me-1"></i> Itens da Movimentação
        </h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50%">Produto</th>
                        <th class="text-center" style="width: 25%">Quantidade</th>
                        <th class="text-end" style="width: 25%">Preço Unitário</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Itens != null && Model.Itens.Any())
                    {
                        foreach (var item in Model.Itens)
                        {
                            <tr>
                                <td class="font-weight-bold">@item.ProdutoNome</td>
                                <td class="text-center">@item.Quantidade</td>
                                <td class="text-end">@item.Preco.ToString("C")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                <i class="fas fa-ghost me-1"></i> Nenhum item registrado nesta movimentação.
                            </td>
                        </tr>
                    }
                </tbody>
                @if (Model.Itens != null && Model.Itens.Any())
                {
                    <tfoot class="table-light font-weight-bold">
                        <tr>
                            <td class="text-end">Total Geral:</td>
                            <td class="text-center">@Model.Itens.Sum(i => i.Quantidade)</td>
                            <td class="text-end text-primary">
                                @Model.Itens.Sum(i => i.Quantidade * i.Preco).ToString("C")
                            </td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>