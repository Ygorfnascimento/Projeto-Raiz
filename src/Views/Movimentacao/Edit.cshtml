@using Raiz.ViewModels;
@using Raiz.Enums;

@model MovimentacaoCadastroViewModel

<h1 class="mt-4">Edição de Movimentação</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a asp-controller="Movimentacao" asp-action="Index">Movimentação</a></li>
    <li class="breadcrumb-item active">Edição</li>
</ol>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-1"></i> @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4 shadow-sm border-left-primary">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-file-alt me-1"></i> Dados do Documento
        </h6>
    </div>
    <div class="card-body bg-light">
        <form asp-action="Finalize" method="post">
            @Html.AntiForgeryToken()
            <div class="row align-items-end g-3">
                <div class="col-md-1">
                    <label asp-for="MovimentacaoId" class="form-label small font-weight-bold">Id</label>
                    <input asp-for="MovimentacaoId" class="form-control bg-white border-0" readonly />
                </div>
                
                <div class="col-md-2">
                    <label asp-for="Documento" class="form-label small font-weight-bold">Documento</label>
                    <input asp-for="Documento" class="form-control bg-white border-0 font-weight-bold" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small font-weight-bold">Data</label>
                    <input value="@Model.DataMovimentacao.ToShortDateString()" class="form-control bg-white border-0" readonly />
                </div>

                <div class="col-md-2">
                    <label class="form-label small font-weight-bold">Tipo</label>
                    <div class="form-control bg-white border-0">
                         <span class="badge @(Model.TipoId == 1 ? "bg-primary" : "bg-info text-dark")">
                            @((TipoMovimentacao)Model.TipoId)
                        </span>
                    </div>
                </div>

                <div class="col-md-5 d-flex justify-content-end pb-1">
                    <button type="submit" class="btn btn-success me-2 shadow-sm" onclick="return confirm('Deseja finalizar esta movimentação e atualizar o estoque?')">
                        <i class="fas fa-check-double me-1"></i> Finalizar Movimentação
                    </button>
                    <a asp-action="Index" class="btn btn-secondary shadow-sm">
                        <i class="fas fa-undo me-1"></i> Voltar
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="px-1">
    <partial name="_AddItem" model="new MovimentacaoItemCadastroViewModel { MovimentacaoId = Model.MovimentacaoId }" />

    <div class="card mb-4 shadow-sm mt-4">
        <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-secondary text-uppercase small">
                <i class="fas fa-shopping-cart me-1"></i> Itens Adicionados
            </h6>
            @if (Model.Itens != null && Model.Itens.Any())
            {
                <span class="badge bg-dark">Total de Itens: @Model.Itens.Count</span>
            }
        </div>
        <div class="card-body p-0"> 
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr class="text-secondary small">
                            <th class="ps-4" style="width: 20%">Cód. Barras</th>
                            <th style="width: 35%">Produto</th>
                            <th class="text-center" style="width: 15%">Quantidade</th>
                            <th class="text-end" style="width: 15%">Preço Unit.</th>
                            <th class="text-center pe-4" style="width: 15%">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Itens != null && Model.Itens.Any())
                        {
                            foreach (var item in Model.Itens)
                            {
                                <tr>
                                    <td class="ps-4 font-monospace small">@item.CodigoBarras</td> 
                                    <td class="font-weight-bold text-dark">@item.ProdutoNome</td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border px-3">@item.Quantidade</span>
                                    </td>
                                    <td class="text-end">@item.Preco.ToString("C2")</td>
                                    <td class="text-center pe-4">
                                        <form asp-action="DeleteItem" asp-route-id="@item.MovimentacaoItemId" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="movimentacaoId" value="@Model.MovimentacaoId" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm border-0" onclick="return confirm('Remover este item?')">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fas fa-barcode fa-3x mb-3 d-block opacity-25"></i>
                                    Nenhum produto adicionado. Use o campo acima para bipar itens.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}