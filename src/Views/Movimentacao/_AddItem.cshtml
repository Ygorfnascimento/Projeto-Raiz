@using Raiz.Models
@using Raiz.Enums

@model MovimentacaoItemCadastroViewModel

<div class="card mb-4 shadow-sm border-left-primary">
    <div class="card-header py-3 bg-white">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-cart-plus me-1"></i> Adicionar Produto à Movimentação
        </h6>
    </div>
    <div class="card-body">
        <form asp-action="AddItem" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MovimentacaoId" />

            <div class="row align-items-end g-3">
                <div class="col-md-4">
                    <label asp-for="CodigoBarras" class="form-label small font-weight-bold">Código de Barras</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="fas fa-barcode"></i></span>
                        <input asp-for="CodigoBarras" class="form-control" tabindex="1" autofocus placeholder="Scanner ou digite..." />
                    </div>
                    <span asp-validation-for="CodigoBarras" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Preco" class="form-label small font-weight-bold">Preço Unitário</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light">R$</span>
                        <input asp-for="Preco" type="number" step="0.01" min="0.01" class="form-control text-end" tabindex="2" placeholder="0,00" />
                    </div>
                    <span asp-validation-for="Preco" class="text-danger small"></span>
                </div>

                <div class="col-md-2">
                    <label asp-for="Quantidade" class="form-label small font-weight-bold">Qtd.</label>
                    <input asp-for="Quantidade" type="number" step="1" min="1" class="form-control text-center" tabindex="3" value="1" />
                    <span asp-validation-for="Quantidade" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100 shadow-sm" tabindex="4">
                        <i class="fas fa-plus me-1"></i> Adicionar Item
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>