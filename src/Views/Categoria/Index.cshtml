@using Raiz.Models;
@model CategoriaPesquisaViewModel;

<h1 class="mt-4">Categorias</h1>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item">Cadastro</li>
    <li class="breadcrumb-item active">Categorias</li>
</ol>

@if (TempData["Mensagem"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-1"></i> @TempData["Mensagem"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-1"></i> @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4 shadow-sm">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-filter me-1"></i> Filtro de Pesquisa
        </h6>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label asp-for="Nome" class="form-label small font-weight-bold">Nome da Categoria</label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Bebidas, Alimentos..." />
                </div>
                <div class="col-md-4 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary me-2 shadow-sm">
                        <i class="fas fa-search"></i> Pesquisar
                    </button>
                    <a asp-action="Index" class="btn btn-secondary me-2 shadow-sm">Limpar</a>
                    
                    @if (User.IsInRole("Gerente"))
                    {
                        <a asp-action="Create" class="btn btn-success shadow-sm">
                            <i class="fas fa-plus"></i> Nova Categoria
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card mb-4 shadow-sm">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-secondary">
            <i class="fas fa-list me-1"></i> Categorias Cadastradas
        </h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4" style="width: 80%">Nome</th>
                        <th style="width: 20%" class="text-center pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Resultados != null && Model.Resultados.Any())
                    {
                        foreach (var categoria in Model.Resultados)
                        {
                            <tr>
                                <td class="ps-4 font-weight-bold text-dark">@categoria.Nome</td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-1">
                                        
                                        @if (User.IsInRole("Gerente"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@categoria.CategoriaId" 
                                               class="btn btn-sm btn-warning text-white shadow-sm" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>

                                            <a asp-action="Delete" asp-route-id="@categoria.CategoriaId" 
                                               class="btn btn-sm btn-danger shadow-sm" title="Remover">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted border">Somente Leitura</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center py-4 text-muted">
                                <i class="fas fa-info-circle me-1"></i> Nenhuma categoria encontrada.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>