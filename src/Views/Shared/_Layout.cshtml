<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Mercearia Raiz</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Raiz.styles.css" asp-append-version="true" />
    
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .sb-nav-link-icon { width: 1.5rem; text-align: center; }
    </style>
</head>

<body class="sb-nav-fixed">
    <nav class="sb-topnav navbar navbar-expand navbar-dark bg-dark shadow">
        <a class="navbar-brand ps-3 font-weight-bold" asp-controller="Home" asp-action="Index">
            <i class="fas fa-store me-2"></i>Mercearia Raiz
        </a>
        <button class="btn btn-link btn-sm order-1 order-lg-0 me-4 me-lg-0" id="sidebarToggle" href="#!">
            <i class="fas fa-bars"></i>
        </button>
        
        <form class="d-none d-md-inline-block form-inline ms-auto me-0 me-md-3 my-2 my-md-0">
            <div class="input-group">
                <input class="form-control" type="text" placeholder="Procurar produto..." aria-label="Search" />
                <button class="btn btn-primary" type="button"><i class="fas fa-search"></i></button>
            </div>
        </form>
        
        <ul class="navbar-nav ms-auto ms-md-0 me-3 me-lg-4">
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-user-circle fa-lg fa-fw"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="navbarDropdown">
                    <li><a class="dropdown-item" href="#!"><i class="fas fa-cog me-2"></i>Configurações</a></li>
                    <li><a class="dropdown-item" href="#!"><i class="fas fa-list me-2"></i>Log de Atividades</a></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="dropdown-item text-danger" href="#!"><i class="fas fa-sign-out-alt me-2"></i>Sair</a></li>
                </ul>
            </li>
        </ul>
    </nav>

    <div id="layoutSidenav">
        <div id="layoutSidenav_nav">
            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion">
                <div class="sb-sidenav-menu">
                    <div class="nav">
                        <div class="sb-sidenav-menu-heading">Início</div>
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-chart-line text-primary"></i></div>
                            Dashboard
                        </a>

                        <div class="sb-sidenav-menu-heading">Operacional</div>
                        <a class="nav-link" asp-controller="Movimentacao" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-exchange-alt text-success"></i></div>
                            Movimentação
                        </a>
                        
                        <div class="sb-sidenav-menu-heading">Cadastros</div>
                        <a class="nav-link" asp-controller="Produto" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-boxes text-warning"></i></div>
                            Produtos
                        </a>
                        <a class="nav-link" asp-controller="Categoria" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-tags text-info"></i></div>
                            Categorias
                        </a>

                        <div class="sb-sidenav-menu-heading">Relatórios</div>
                        <a class="nav-link disabled" href="#">
                            <div class="sb-nav-link-icon"><i class="fas fa-file-invoice-dollar"></i></div>
                            Fechamento Mensal
                        </a>
                    </div>
                </div>
                <div class="sb-sidenav-footer">
                    <div class="small">Logado como:</div>
                    <span class="badge bg-success">Administrador</span>
                </div>
            </nav>
        </div>

        <div id="layoutSidenav_content" class="bg-light">
            <main>
                <div class="container-fluid px-4">
                    @RenderBody()
                </div>
            </main>
            
            <footer class="py-4 bg-white mt-auto border-top">
                <div class="container-fluid px-4">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div class="text-muted">
                            &copy; @DateTime.Now.Year - <strong>Raiz Sistema de Estoque</strong>
                        </div>
                        <div>
                            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacidade</a>
                            &middot;
                            <span class="text-muted">Versão 1.0</span>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>