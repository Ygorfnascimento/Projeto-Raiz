@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - Mercearia Raiz</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Raiz.styles.css" asp-append-version="true" />
    
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; overflow-x: hidden; }
        .sb-nav-link-icon { width: 1.5rem; text-align: center; }
        .btn-logout { width: 100%; text-align: left; padding: 0.5rem 1rem; border: 0; background: none; color: #dc3545 !important; }
        .btn-logout:hover { background-color: #f8f9fa; }
        .badge-role { font-size: 0.75rem; padding: 0.4em 0.8em; }

        .sb-nav-fixed #layoutSidenav_nav {
            width: 280px; 
            min-width: 200px;
            max-width: 500px;
            position: fixed;
            top: 56px;
            height: calc(100vh - 56px);
            z-index: 1038;
            transition: width 0.15s ease-in-out;
        }

        #sidebarResizer {
            position: absolute;
            top: 0;
            right: 0;
            width: 6px; 
            height: 100%;
            cursor: col-resize;
            z-index: 1050;
            background: transparent;
        }

        #sidebarResizer:hover { background: rgba(13, 110, 253, 0.3); }

        .sb-nav-fixed #layoutSidenav_content {
            padding-left: 280px; 
            transition: padding-left 0.15s ease-in-out;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        body.sb-sidenav-toggled #layoutSidenav_nav { width: 0 !important; transform: translateX(-280px); }
        body.sb-sidenav-toggled #layoutSidenav_content { padding-left: 0 !important; }

        .sb-sidenav-footer {
            padding: 0.75rem;
            background-color: #343a40;
            margin-top: auto;
        }
        
        .user-info-text {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            display: block;
            max-width: 100%;
            color: rgba(255, 255, 255, 0.8);
        }

        /* Melhoria: cursor e remoção de estilo de link no nome da marca */
        #sidebarToggleBrand { cursor: pointer; text-decoration: none; user-select: none; }
    </style>
</head>

<body class="sb-nav-fixed">
    <nav class="sb-topnav navbar navbar-expand navbar-dark bg-dark shadow">
        @* Link ajustado para não navegar, apenas disparar o clique *@
        <a class="navbar-brand ps-3 font-weight-bold" id="sidebarToggleBrand" href="javascript:void(0)">
            <i class="fas fa-store me-2 text-primary"></i>Mercearia Raiz
        </a>
        <button class="btn btn-link btn-sm order-1 order-lg-0 me-4 me-lg-0" id="sidebarToggle">
            <i class="fas fa-bars"></i>
        </button>
        
        <div class="ms-auto"></div>
        
        <ul class="navbar-nav me-3 me-lg-4">
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-user-circle fa-lg fa-fw"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="navbarDropdown">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li>
                            <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                                <i class="fas fa-user me-2"></i>Meu Perfil
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Movimentacao", new { area = "" })" method="post">
                                <button type="submit" class="dropdown-item btn-logout">
                                    <i class="fas fa-sign-out-alt me-2"></i>Sair
                                </button>
                            </form>
                        </li>
                    }
                </ul>
            </li>
        </ul>
    </nav>

    <div id="layoutSidenav">
        <div id="layoutSidenav_nav">
            <div id="sidebarResizer"></div>

            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion">
                <div class="sb-sidenav-menu">
                    <div class="nav">
                        
                        @if (User.IsInRole("Gerente"))
                        {
                            <div class="sb-sidenav-menu-heading">Principal</div>
                            <a class="nav-link" asp-controller="Relatorio" asp-action="Index">
                                <div class="sb-nav-link-icon"><i class="fas fa-tachometer-alt text-primary"></i></div>
                                Dashboard
                            </a>
                        }

                        <div class="sb-sidenav-menu-heading">Operacional</div>
                        <a class="nav-link" asp-controller="Movimentacao" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-exchange-alt text-success"></i></div>
                            Movimentação
                        </a>
                        
                        <div class="sb-sidenav-menu-heading">Cadastros</div>
                        <a class="nav-link" asp-controller="Produto" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-boxes text-warning"></i></div>
                            Produtos
                        </a>
                        <a class="nav-link" asp-controller="Categoria" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-tags text-info"></i></div>
                            Categorias
                        </a>

                        @if (User.IsInRole("Gerente"))
                        {
                            <div class="sb-sidenav-menu-heading">Relatórios</div>
                            <a class="nav-link" asp-controller="Relatorio" asp-action="ProdutosPorCategoria">
                                <div class="sb-nav-link-icon"><i class="fas fa-chart-pie text-info"></i></div>
                                Produtos por Categoria
                            </a>
                            <a class="nav-link" asp-controller="Relatorio" asp-action="MovimentacoesResumo">
                                <div class="sb-nav-link-icon"><i class="fas fa-file-invoice-dollar text-success"></i></div>
                                Movimentações por Tipo
                            </a>

                            <div class="sb-sidenav-menu-heading">Administração</div>
                            <a class="nav-link" asp-controller="Usuario" asp-action="Index">
                                <div class="sb-nav-link-icon"><i class="fas fa-users-cog text-secondary"></i></div>
                                Usuários
                            </a>
                        }
                    </div>
                </div>
                
                <div class="sb-sidenav-footer">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <div class="small text-muted">Usuário logado:</div>
                        <div class="user-info-text mb-2 text-white">@User.Identity?.Name</div>
                        
                        @if (User.IsInRole("Gerente"))
                        {
                            <span class="badge bg-danger badge-role text-uppercase shadow-sm">Gerente</span>
                        }
                        else
                        {
                            <span class="badge bg-success badge-role text-uppercase shadow-sm">Operador</span>
                        }
                    }
                </div>
            </nav>
        </div>

        <div id="layoutSidenav_content" class="bg-light">
            <main>
                <div class="container-fluid px-4 pt-3">
                    @RenderBody()
                </div>
            </main>
            
            <footer class="py-4 bg-white mt-auto border-top">
                <div class="container-fluid px-4">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div class="text-muted">
                            &copy; @DateTime.Now.Year - <strong>Mercearia Raiz</strong>
                        </div>
                        <div>
                            <span class="badge text-dark border">v1.0.4-estável</span>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const nav = document.getElementById('layoutSidenav_nav');
            const content = document.getElementById('layoutSidenav_content');
            const resizer = document.getElementById('sidebarResizer');
            const toggle = document.getElementById('sidebarToggle');
            const toggleBrand = document.getElementById('sidebarToggleBrand');

            function handleToggle(e) {
                if(e) e.preventDefault();
                document.body.classList.toggle('sb-sidenav-toggled');
            }

            if (toggle) toggle.addEventListener('click', handleToggle);
            if (toggleBrand) toggleBrand.addEventListener('click', handleToggle);

            if (resizer && nav && content) {
                resizer.addEventListener('mousedown', function (e) {
                    e.preventDefault();
                    document.addEventListener('mousemove', handleMouseMove);
                    document.addEventListener('mouseup', stopResizing);
                    document.body.style.cursor = 'col-resize';
                    nav.style.transition = 'none';
                    content.style.transition = 'none';
                });
            }

            function handleMouseMove(e) {
                let newWidth = e.clientX;
                if (newWidth > 200 && newWidth < 500) {
                    nav.style.width = newWidth + 'px';
                    content.style.paddingLeft = newWidth + 'px';
                }
            }

            function stopResizing() {
                document.removeEventListener('mousemove', handleMouseMove);
                document.removeEventListener('mouseup', stopResizing);
                document.body.style.cursor = 'default';
                nav.style.transition = 'width 0.15s ease-in-out';
                content.style.transition = 'padding-left 0.15s ease-in-out';
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>