<div class="row">
    @if (User.IsInRole("Gerente"))
    {
        <div class="col-xl-3 col-md-6">
            <div class="card bg-primary text-white mb-4 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-dollar-sign fa-2x me-2"></i>
                    <div>Faturamento Mensal</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <span class="h5 mb-0 text-white">R$ 15.240,00</span>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-success text-white mb-4 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-users fa-2x me-2"></i>
                    <div>Usuários Ativos</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <span class="h5 mb-0 text-white">5 Colaboradores</span>
                </div>
            </div>
        </div>
    }

    <div class="col-xl-3 col-md-6">
        <div class="card bg-warning text-white mb-4 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-exclamation-triangle fa-2x me-2"></i>
                <div>Estoque Baixo</div>
            </div>
            <div class="card-footer d-flex align-items-center justify-content-between">
                <span class="h5 mb-0 text-white">12 Itens</span>
                <a class="small text-white stretched-link" asp-controller="Produto" asp-action="Index">Ver mais</a>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card bg-info text-white mb-4 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <i class="fas fa-box fa-2x me-2"></i>
                <div>Total de Produtos</div>
            </div>
            <div class="card-footer d-flex align-items-center justify-content-between">
                <span class="h5 mb-0 text-white">145 Itens</span>
            </div>
        </div>
    </div>
</div>